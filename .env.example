# Modal endpoint for the chat backend, printed by `modal deploy`.
# Read at build time by src/lib/chat/client.ts.
PUBLIC_CHAT_API=https://your-workspace--portfolio-chat-web.modal.run

# Absolute site URL, and the subpath. This repo is a GitHub *project* site, so
# BASE is the repo name; it would be "/" only for hotpath-hooligan.github.io.
SITE=https://hotpath-hooligan.github.io
BASE=/portfolio/
