---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Callback requested · Aryan Kapoor"
  description="Your callback request has been sent to Aryan Kapoor."
>
  <main id="main-content" class="confirmation-page">
    <section aria-labelledby="confirmation-title">
      <p class="eyebrow">Request received</p>
      <h1 id="confirmation-title">Thanks. I’ll be in touch.</h1>
      <p>Your callback request has been sent. I’ll get back to you using the contact details you provided.</p>
      <a class="button" href={base}>
        Back to the portfolio
        <span aria-hidden="true">←</span>
      </a>
    </section>
  </main>
</Layout>
