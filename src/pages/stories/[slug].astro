---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { slugify } from '../../lib/slug.ts';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories
    .filter((s) => !s.data.draft)
    .map((story) => ({ params: { slug: story.id }, props: { story } }));
}

const { story } = Astro.props;
const { Content } = await render(story);
const { title, blurb, role, domain, highlight } = story.data;
---

<Layout title={`${title} · Aryan Kapoor`} description={blurb}>
  <main class="mx-auto max-w-3xl px-6 pb-32">
    <a
      href="/#stories"
      class="mt-16 inline-block text-sm text-slate-400 underline-offset-4 transition hover:text-slate-700 hover:underline dark:hover:text-slate-200"
    >
      ← Back
    </a>

    <header class="mt-8">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-white">
        {title}
      </h1>
      <p class="mt-3 text-lg text-slate-600 dark:text-slate-400">{blurb}</p>

      <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">
        <span class="font-medium text-slate-700 dark:text-slate-300">My part:</span>
        {' '}{role}
        {
          highlight && (
            <>
              {' · '}
              <a
                href={`/#${slugify(highlight)}`}
                class="underline-offset-4 transition hover:text-slate-900 hover:underline dark:hover:text-white"
              >
                {highlight}
              </a>
            </>
          )
        }
      </p>

      <ul class="mt-5 flex flex-wrap gap-1.5">
        {
          domain.map((d) => (
            <li class="rounded border border-slate-200 px-2 py-0.5 text-xs text-slate-500 dark:border-slate-700 dark:text-slate-400">
              {d}
            </li>
          ))
        }
      </ul>
    </header>

    <div class="story mt-12 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
      <Content />
    </div>
  </main>
</Layout>

<style>
  /* Case studies are the only long-form Markdown on the site, so the element
     styling lives here rather than in global.css where nothing else needs it. */
  .story :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-slate-900);
  }
  .story :global(h3) {
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
    color: var(--color-slate-800);
  }
  .story :global(p),
  .story :global(ul),
  .story :global(ol) {
    margin-bottom: 1rem;
  }
  .story :global(ul) {
    list-style: disc;
    padding-left: 1.25rem;
  }
  .story :global(ol) {
    list-style: decimal;
    padding-left: 1.25rem;
  }
  .story :global(li) {
    margin-bottom: 0.375rem;
  }
  .story :global(strong) {
    font-weight: 600;
    color: var(--color-slate-800);
  }
  .story :global(code) {
    border-radius: 0.25rem;
    background: var(--color-slate-100);
    padding: 0.1rem 0.3rem;
    font-size: 0.85em;
  }
  /* Tables carry the tradeoff matrices; they must scroll rather than push the
     page into horizontal overflow on a phone. */
  .story :global(table) {
    display: block;
    overflow-x: auto;
    width: 100%;
    margin-bottom: 1.25rem;
    border-collapse: collapse;
    font-size: 0.8125rem;
  }
  .story :global(th),
  .story :global(td) {
    border: 1px solid var(--color-slate-200);
    padding: 0.5rem 0.625rem;
    text-align: left;
    vertical-align: top;
  }
  .story :global(th) {
    font-weight: 600;
    color: var(--color-slate-700);
  }

  /* The rest of the site uses Tailwind's `dark:` variant, which resolves to
     prefers-color-scheme here — there is no `.dark` class to hook. */
  @media (prefers-color-scheme: dark) {
    .story :global(h2) {
      color: white;
    }
    .story :global(h3),
    .story :global(strong),
    .story :global(th) {
      color: var(--color-slate-200);
    }
    .story :global(code) {
      background: var(--color-slate-800);
    }
    .story :global(th),
    .story :global(td) {
      border-color: var(--color-slate-800);
    }
  }
</style>
