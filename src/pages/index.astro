---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import ProjectCover from '../components/ProjectCover.astro';
import { slugify } from '../lib/slug.ts';

const published = <T extends { data: { draft: boolean } }>(items: T[]) =>
  items.filter((item) => !item.data.draft);
const byOrder = (a: any, b: any) => (b.data.order ?? 0) - (a.data.order ?? 0);

const profile = published(await getCollection('profile'))[0];
if (!profile) throw new Error('src/content/profile/index.md is required (and must not be draft)');
const { name, tagline, location, links } = profile.data;

const about = published(await getCollection('about'))[0];
const AboutContent = about ? (await render(about)).Content : null;

const experience = published(await getCollection('experience')).sort(byOrder);
const projects = published(await getCollection('projects')).sort(byOrder);
const skills = published(await getCollection('skills'))[0];
const SkillsContent = skills ? (await render(skills)).Content : null;
const certifications = published(await getCollection('certifications')).sort(byOrder);
const education = published(await getCollection('education')).sort(byOrder);
const interests = published(await getCollection('interests')).sort(byOrder);
const renderedInterests = await Promise.all(
  interests.map(async (interest) => ({
    interest,
    Content: (await render(interest)).Content,
  })),
);

const featuredProjects = projects.filter((project) => project.data.featured).slice(0, 2);
const otherProjects = projects.filter((project) => !featuredProjects.includes(project));
const base = import.meta.env.BASE_URL;
---

<Layout>
  <main id="main-content">
    <section id="top" class="hero">
      <div class="hero__inner">
        <div class="hero__copy">
          <p class="eyebrow">
            {name}
            <span aria-hidden="true">/</span>
            {location}
          </p>
          <h1>Architecting the invisible.<br />Scaling the impossible.</h1>
          <p class="hero__lede">{tagline}</p>

          <div class="hero__actions">
            <a class="button" href="#experience">
              Explore selected work
              <span aria-hidden="true">↓</span>
            </a>
          </div>

          <p class="hero__note">
            <span class="status-dot" aria-hidden="true"></span>
            Open to backend, platform, and infrastructure roles
          </p>
        </div>

        <div class="system-map" aria-hidden="true">
          <div class="system-map__header">
            <span>System map / 01</span>
            <span class="system-map__status"><i></i> All paths observable</span>
          </div>

          <svg viewBox="0 0 620 480" role="presentation">
            <defs>
              <pattern id="map-grid" width="28" height="28" patternUnits="userSpaceOnUse">
                <path d="M28 0H0V28" class="map-grid-line"></path>
              </pattern>
            </defs>
            <rect width="620" height="480" fill="url(#map-grid)"></rect>

            <path class="map-route map-route--one" d="M95 119H245V238H375"></path>
            <path class="map-route map-route--two" d="M525 119H410V238H375"></path>
            <path class="map-route map-route--three" d="M375 238V360H503"></path>
            <path class="map-route map-route--four" d="M375 238H228V360H110"></path>

            <g class="map-node" transform="translate(48 86)">
              <rect width="112" height="66" rx="8"></rect>
              <circle cx="20" cy="20" r="5"></circle>
              <text x="18" y="45">EDGE</text>
            </g>
            <g class="map-node" transform="translate(460 86)">
              <rect width="112" height="66" rx="8"></rect>
              <circle cx="20" cy="20" r="5"></circle>
              <text x="18" y="45">EVENTS</text>
            </g>
            <g class="map-node map-node--primary" transform="translate(306 199)">
              <rect width="138" height="78" rx="10"></rect>
              <circle cx="22" cy="22" r="6"></circle>
              <text x="20" y="51">SYSTEMS</text>
            </g>
            <g class="map-node" transform="translate(55 327)">
              <rect width="112" height="66" rx="8"></rect>
              <circle cx="20" cy="20" r="5"></circle>
              <text x="18" y="45">POLICY</text>
            </g>
            <g class="map-node" transform="translate(448 327)">
              <rect width="112" height="66" rx="8"></rect>
              <circle cx="20" cy="20" r="5"></circle>
              <text x="18" y="45">STATE</text>
            </g>

            <circle class="map-packet map-packet--one" r="5">
              <animateMotion dur="4s" repeatCount="indefinite" path="M95 119H245V238H375"></animateMotion>
            </circle>
            <circle class="map-packet map-packet--two" r="5">
              <animateMotion dur="5s" repeatCount="indefinite" path="M525 119H410V238H375"></animateMotion>
            </circle>
          </svg>

          <div class="system-map__footer">
            <span>Packets</span>
            <i></i>
            <span>Decisions</span>
            <i></i>
            <span>State</span>
          </div>
        </div>
      </div>

      <dl class="proof-bar">
        <div>
          <dt>6+</dt>
          <dd>Years building production systems</dd>
        </div>
      </dl>
    </section>

    <div class="page-shell">
      <Section
        id="experience"
        index="01"
        eyebrow="Experience"
        title="Platform work with real operating constraints."
        lead="Distributed state, secure remote access, multi-region delivery, and the networking underneath it."
      >
        <div class="experience-list">
          {
            experience.map((job, jobIndex) => {
              const primaryHighlights =
                jobIndex === 0 ? job.data.highlights.slice(0, 4) : job.data.highlights;
              const additionalHighlights =
                jobIndex === 0 ? job.data.highlights.slice(4) : [];

              return (
                <article class="role-card" id={slugify(job.data.company)}>
                  <div class="role-card__intro">
                    <div class="role-card__title">
                      <p class="role-card__date">
                        {job.data.start} — {job.data.end}
                        {job.data.end === 'Present' && <span>Current</span>}
                      </p>
                      <h3>{job.data.role}</h3>
                      <p>{job.data.company}{job.data.location && ` · ${job.data.location}`}</p>
                    </div>
                    <p class="role-card__summary">{job.data.summary}</p>
                  </div>

                  <div class="workstream-grid">
                    {primaryHighlights.map((highlight, index) => (
                      <div class="workstream" id={slugify(highlight.name)}>
                        <span class="workstream__number">{String(index + 1).padStart(2, '0')}</span>
                        <h4>{highlight.name}</h4>
                        <p>{highlight.detail}</p>
                        <div class="workstream__footer">
                          <span>{highlight.tech.slice(0, 4).join(' · ')}</span>
                        </div>
                      </div>
                    ))}
                  </div>

                  {additionalHighlights.length > 0 && (
                    <details class="work-more">
                      <summary>
                        <span>Explore more work at {job.data.company}</span>
                        <span>{additionalHighlights.length} workstreams <i aria-hidden="true">+</i></span>
                      </summary>
                      <div class="workstream-grid workstream-grid--more">
                        {additionalHighlights.map((highlight, index) => (
                          <div class="workstream" id={slugify(highlight.name)}>
                            <span class="workstream__number">
                              {String(index + primaryHighlights.length + 1).padStart(2, '0')}
                            </span>
                            <h4>{highlight.name}</h4>
                            <p>{highlight.detail}</p>
                            <div class="workstream__footer">
                              <span>{highlight.tech.slice(0, 4).join(' · ')}</span>
                            </div>
                          </div>
                        ))}
                      </div>
                    </details>
                  )}
                </article>
              );
            })
          }
        </div>
      </Section>

      <Section
        id="projects"
        index="02"
        eyebrow="Independent builds"
        title="Learning the mechanism, not just the interface."
        lead="Emulators, network simulators, kernels, games, and small products—built to understand where the abstraction ends."
      >
        <div class="featured-projects">
          {
            featuredProjects.map((project) => (
              <a class="project-card" href={`${base}projects/${project.id}/`}>
                <div class="project-card__cover">
                  <ProjectCover
                    cover={project.data.cover}
                    title={project.data.title}
                    year={project.data.year}
                    decorative
                  />
                </div>
                <div class="project-card__copy">
                  <div>
                    <p>{project.data.stack.slice(0, 3).join(' · ')}</p>
                    <h3>{project.data.title}</h3>
                  </div>
                  <span aria-hidden="true">↗</span>
                </div>
                <p class="project-card__blurb">{project.data.blurb}</p>
              </a>
            ))
          }
        </div>

        {
          otherProjects.length > 0 && (
            <div class="project-list">
              {otherProjects.map((project) => (
                <a href={`${base}projects/${project.id}/`}>
                  <div>
                    <h3>{project.data.title}</h3>
                    <p>{project.data.blurb}</p>
                  </div>
                  <span>{project.data.stack.slice(0, 3).join(' · ')}</span>
                  <i aria-hidden="true">↗</i>
                </a>
              ))}
            </div>
          )
        }
      </Section>

      {
        AboutContent && (
          <Section
            id="about"
            index="03"
            eyebrow="About"
            title={about?.data.tagline ?? 'Systems, all the way down.'}
          >
            <div class="about-grid">
              <div class="prose prose--large">
                <AboutContent />
              </div>

              <dl class="profile-facts">
                <div>
                  <dt>Based in</dt>
                  <dd>{location}</dd>
                </div>
                <div>
                  <dt>Strongest at</dt>
                  <dd>Backend · Platform · Networking</dd>
                </div>
                <div>
                  <dt>Working style</dt>
                  <dd>Explicit trade-offs and observable failure modes</dd>
                </div>
                <div>
                  <dt>Find me</dt>
                  <dd>
                    {links.map((link, index) => (
                      <>
                        {index > 0 && ' · '}
                        <a href={link.url} rel="me">{link.label}</a>
                      </>
                    ))}
                  </dd>
                </div>
              </dl>
            </div>

            <div class="principles">
              <div>
                <span>01</span>
                <h3>Design for recovery.</h3>
                <p>Retries, replay, cleanup, and restart behavior belong in the first design.</p>
              </div>
              <div>
                <span>02</span>
                <h3>Make failure legible.</h3>
                <p>A system is easier to trust when its decisions and degraded states are visible.</p>
              </div>
              <div>
                <span>03</span>
                <h3>Name the trade-off.</h3>
                <p>The best architecture is contextual. State what it buys and what it costs.</p>
              </div>
            </div>
          </Section>
        )
      }

      {
        skills && (
          <Section
            id="skills"
            index="04"
            eyebrow="Capabilities"
            title="The toolkit follows the problem."
            lead="A focused view of the languages, platforms, and protocols I use to move from design to production."
          >
            <div class="skills-grid">
              {skills.data.groups.map((group) => (
                <div class="skill-group">
                  <h3>{group.name}</h3>
                  <p>{group.items.join(' · ')}</p>
                </div>
              ))}
            </div>

            {SkillsContent && (
              <div class="prose skills-note">
                <SkillsContent />
              </div>
            )}

            <div class="credentials-grid">
              <div class="credential-block">
                <p class="eyebrow">Credentials</p>
                {certifications.map((certification) => (
                  <div>
                    <h3>
                      {certification.data.url ? (
                        <a href={certification.data.url}>{certification.data.name}</a>
                      ) : (
                        certification.data.name
                      )}
                    </h3>
                    <p>{certification.data.issuer}</p>
                    <span>{certification.data.date}</span>
                  </div>
                ))}
              </div>

              <div class="credential-block">
                <p class="eyebrow">Education</p>
                {education.map((entry) => (
                  <div>
                    <h3>{entry.data.institution}</h3>
                    <p>{entry.data.degree}</p>
                    <span>
                      {entry.data.start} — {entry.data.end}
                      {entry.data.location && ` · ${entry.data.location}`}
                    </span>
                  </div>
                ))}
              </div>
            </div>

            {renderedInterests.length > 0 && (
              <div class="interests">
                <p class="eyebrow">Away from the terminal</p>
                <div class="interests__grid">
                  {renderedInterests.map(({ interest, Content }) => (
                    <div>
                      <span aria-hidden="true">{interest.data.icon}</span>
                      <h3>{interest.data.title}</h3>
                      <div class="prose"><Content /></div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </Section>
        )
      }
    </div>
  </main>
</Layout>
