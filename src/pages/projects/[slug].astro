---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import ProjectCover from '../../components/ProjectCover.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects
    .filter((p) => !p.data.draft)
    .map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={`${project.data.title} · Aryan Kapoor`} description={project.data.blurb}>
  <main class="mx-auto max-w-3xl px-6 pb-32">
    <a
      href="/#projects"
      class="mt-16 inline-block text-sm text-slate-400 underline-offset-4 transition hover:text-slate-700 hover:underline dark:hover:text-slate-200"
    >
      ← Back
    </a>

    <header class="mt-8">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-white">
        {project.data.title}
      </h1>
      <p class="mt-3 text-lg text-slate-600 dark:text-slate-400">{project.data.blurb}</p>

      <ul class="mt-5 flex flex-wrap gap-1.5">
        {
          project.data.stack.map((s) => (
            <li class="rounded border border-slate-200 px-2 py-0.5 text-xs text-slate-500 dark:border-slate-700 dark:text-slate-400">
              {s}
            </li>
          ))
        }
      </ul>

      {
        (project.data.repo || project.data.demo) && (
          <div class="mt-5 flex gap-4 text-sm">
            {project.data.repo && (
              <a
                href={project.data.repo}
                class="text-slate-500 underline-offset-4 transition hover:text-slate-900 hover:underline dark:hover:text-white"
              >
                Source
              </a>
            )}
            {project.data.demo && (
              <a
                href={project.data.demo}
                class="text-slate-500 underline-offset-4 transition hover:text-slate-900 hover:underline dark:hover:text-white"
              >
                Demo
              </a>
            )}
          </div>
        )
      }
    </header>

    <div class="mt-10 aspect-[16/9] w-full overflow-hidden rounded-xl border border-slate-200 dark:border-slate-800">
      <ProjectCover cover={project.data.cover} title={project.data.title} widths={[800, 1400]} />
    </div>

    <div
      class="mt-10 space-y-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400"
    >
      <Content />
    </div>

    {
      project.data.gallery.length > 0 && (
        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {project.data.gallery.map((g) => (
            <figure>
              <Image
                src={g.src}
                alt={g.alt}
                widths={[400, 800]}
                sizes="(max-width: 640px) 100vw, 400px"
                loading="lazy"
                decoding="async"
                class="w-full rounded-lg border border-slate-200 dark:border-slate-800"
              />
              <figcaption class="mt-2 text-xs text-slate-400 dark:text-slate-500">{g.alt}</figcaption>
            </figure>
          ))}
        </div>
      )
    }
  </main>
</Layout>
