---
interface Link {
  label: string;
  url: string;
}

interface Props {
  name: string;
  email?: string;
  links?: Link[];
}

const { name, email, links = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
const externalLinks = links.filter((link) => ['GitHub', 'LinkedIn'].includes(link.label));
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href={base} aria-label={`${name}, home`}>
      <span class="brand__mark" aria-hidden="true">AK</span>
      <span class="brand__text">
        <strong>{name}</strong>
        <span>Software engineer</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      <a href={`${base}#experience`}>Work</a>
      <a href={`${base}#projects`}>Projects</a>
      {
        externalLinks.map((link) => (
          <a class="site-nav__external" href={link.url} rel="me">
            {link.label}
          </a>
        ))
      }
      {
        email && (
          <a class="button button--small" href={`${base}#contact`}>
            Let’s talk
            <span aria-hidden="true">↓</span>
          </a>
        )
      }
    </nav>
  </div>
</header>
