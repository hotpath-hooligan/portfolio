---
interface Props {
  id: string;
  title: string;
  index?: string;
  eyebrow?: string;
  lead?: string;
}
const { id, title, index, eyebrow, lead } = Astro.props;
---

<section id={id} class="page-section">
  <header class="section-heading">
    <div class="section-heading__label">
      {index && <span class="section-index">{index}</span>}
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    </div>
    <div class="section-heading__copy">
      <h2>{title}</h2>
      {lead && <p>{lead}</p>}
    </div>
  </header>
  <div class="section-content">
    <slot />
  </div>
</section>
