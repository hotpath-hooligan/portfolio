---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  cover?: ImageMetadata;
  title: string;
  year?: string;
  widths?: number[];
  decorative?: boolean;
  class?: string;
}

const {
  cover,
  title,
  year,
  widths = [400, 800],
  decorative = false,
  class: className = '',
} = Astro.props;

/**
 * Deterministic, code-native art for projects without screenshots. The title
 * selects a palette and motif, so every project remains visually distinct.
 */
const hash = [...title].reduce((h, c) => (h * 31 + c.charCodeAt(0)) >>> 0, 7);
const hue = [12, 42, 158, 197, 224, 266][hash % 6];
const variant = hash % 4;
const initials = title
  .split(/\s+/)
  .slice(0, 2)
  .map((w) => w[0])
  .join('')
  .toUpperCase();
---

{
  cover ? (
    <Image
      src={cover}
      alt={decorative ? '' : `${title} project cover`}
      widths={widths}
      sizes="(max-width: 640px) 100vw, 400px"
      loading="lazy"
      decoding="async"
      class={`h-full w-full object-cover ${className}`}
    />
  ) : (
    <div
      class={`project-art ${className}`}
      data-variant={variant}
      style={`--cover-hue: ${hue}`}
      aria-hidden="true"
    >
      <span class="project-art__meta">{year ?? 'Independent build'}</span>
      <span class="project-art__initials">{initials}</span>
      <span class="project-art__title">{title}</span>
      <span class="project-art__orb project-art__orb--one"></span>
      <span class="project-art__orb project-art__orb--two"></span>
      <span class="project-art__line project-art__line--one"></span>
      <span class="project-art__line project-art__line--two"></span>
    </div>
  )
}
